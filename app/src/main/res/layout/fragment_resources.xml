<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/harm_reduction_resources"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:layout_marginBottom="16dp"/>

        <!-- Help & Links -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_help_links"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_help"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/support_help_body"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:layout_marginBottom="8dp"/>
                <Button
                    android:id="@+id/btn_emergency_contacts"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/emergency_contacts"
                    android:gravity="start"
                    app:icon="@android:drawable/ic_menu_call" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Reagent Charts -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_reagent_charts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reagent_colour_charts"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reagent_charts_body"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:layout_marginBottom="8dp"/>
                <Button
                    android:id="@+id/btn_view_charts"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/view_all_charts" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Calculators -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_calculators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dosing_calculators"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dosing_calculators_body"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:layout_marginBottom="8dp"/>
                <Button
                    android:id="@+id/btn_volumetric_calc"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/volumetric_dosing" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Interaction Checker -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_interactions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/drug_interactions"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/drug_interactions_body"
                    android:textAppearance="@style/TextAppearance.Material3.BodySmall"
                    android:layout_marginBottom="8dp"/>
                <Button
                    android:id="@+id/btn_check_interactions"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/open_interaction_checker" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>


