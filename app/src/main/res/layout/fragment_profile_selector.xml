<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:padding="24dp">

    <!-- Settings Button (Top Right) -->
    <ImageButton
        android:id="@+id/btn_global_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="-8dp"
        android:layout_marginRight="-8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/action_settings"
        android:src="@drawable/ic_settings_custom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="?attr/colorOnSurfaceVariant" />

    <!-- Branded Header Section (Pill above Title) -->
    <ImageView
        android:id="@+id/img_pill_header"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_pill_logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/brand_purple" />

    <LinearLayout
        android:id="@+id/layout_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/img_pill_header">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:alpha="0.8"
            android:letterSpacing="0.05"
            android:text="DRUG"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.05"
            android:text="DIARY"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/brand_purple"
            android:textStyle="bold" />
    </LinearLayout>


    <TextView
        android:id="@+id/text_login_heading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:alpha="0.7"
        android:text="@string/welcome_description_short"
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_title"
        android:gravity="center"/>

    <!-- Anchor for Profile Section -->
    <View
        android:id="@+id/selection_anchor"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/text_login_heading" />

    <!-- Profile Selection Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_profile_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toTopOf="@id/selection_anchor"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layout_selected_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:padding="16dp">

            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <brettdansmith.drugdiary.ui.avatar.ProfileAvatarView
                    android:id="@+id/view_avatar_selected"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </FrameLayout>

            <TextView
                android:id="@+id/text_profile_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/img_arrow"
                app:layout_constraintStart_toEndOf="@id/avatar_container"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Select Profile" />

            <ImageView
                android:id="@+id/img_arrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Expand"
                android:src="@drawable/ic_chevron_down"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?attr/colorOnSurfaceVariant" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Expanded Overlay View -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_profile_expanded"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurfaceVariant"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_default="wrap"
        app:layout_constraintTop_toTopOf="@id/selection_anchor"
        app:layout_constraintVertical_bias="0.0"
        app:strokeColor="?attr/colorOutline"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_header_expanded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackground"
                android:padding="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/avatar_container_exp"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <brettdansmith.drugdiary.ui.avatar.ProfileAvatarView
                        android:id="@+id/view_avatar_selected_exp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                </FrameLayout>

                <TextView
                    android:id="@+id/text_profile_name_exp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/img_arrow_exp"
                    app:layout_constraintStart_toEndOf="@id/avatar_container_exp"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/img_arrow_exp"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Collapse"
                    android:rotation="180"
                    android:src="@drawable/ic_chevron_down"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/divider_expanded"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/colorOutline"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/layout_header_expanded" />

            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_other_profiles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:alpha="0"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:visibility="gone"
                app:layout_constrainedHeight="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_expanded">

                <LinearLayout
                    android:id="@+id/container_other_profiles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </androidx.core.widget.NestedScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Feedback Container (Integrated Loading/Error) -->
    <LinearLayout
        android:id="@+id/layout_status_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/label_enter_pin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_profile_selector"
        app:layout_constraintVertical_bias="0.5">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ProgressBar
                android:id="@+id/progress_unlocking"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminateTint="@color/brand_purple"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/img_unlock_error"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_dialog_alert"
                android:visibility="gone"
                app:tint="@color/light_error" />
        </FrameLayout>

        <TextView
            android:id="@+id/text_unlock_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:visibility="gone"
            tools:text="Unlocking profile..."
            tools:visibility="visible" />
    </LinearLayout>

    <TextView
        android:id="@+id/label_enter_pin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:letterSpacing="0.1"
        android:text="ENTER PIN"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintBottom_toTopOf="@id/layout_pin_dots"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layout_pin_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/grid_pin_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- PIN Pad -->
    <GridLayout
        android:id="@+id/grid_pin_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_1"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="1" />

        <Button
            android:id="@+id/btn_2"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="2" />

        <Button
            android:id="@+id/btn_3"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="3" />

        <Button
            android:id="@+id/btn_4"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="4" />

        <Button
            android:id="@+id/btn_5"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="5" />

        <Button
            android:id="@+id/btn_6"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="6" />

        <Button
            android:id="@+id/btn_7"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="7" />

        <Button
            android:id="@+id/btn_8"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="8" />

        <Button
            android:id="@+id/btn_9"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="9" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1" />

        <Button
            android:id="@+id/btn_0"
            style="@style/Widget.DrugDiary.PinButton"
            android:text="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_delete"
            style="@style/Widget.DrugDiary.PinButton.Icon"
            app:icon="@drawable/ic_backspace_outline"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
